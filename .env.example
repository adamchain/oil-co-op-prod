# MongoDB Atlas (required on Railway server service — without it the app defaults to 127.0.0.1:27017 and crashes)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/oilcoop?retryWrites=true&w=majority

# Server
PORT=4000
JWT_SECRET=change-me-in-production-min-32-chars

# URLs (for CORS and email links)
CLIENT_ORIGIN=http://localhost:5173

# --- Split deploy (separate Railway “client” + “server” services) ---
# Server: set CLIENT_ORIGIN to the SPA’s public URL (e.g. https://your-app.up.railway.app).
# Client: at build time, set VITE_API_URL to the API’s public URL (same as below, in client service only).
# VITE_API_URL=https://your-api.up.railway.app

# Stripe (optional — without keys, signup uses mock payment success in dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Fees (cents)
REGISTRATION_FEE_CENTS=5000
ANNUAL_FEE_CENTS=12000

# Email (optional — logs to console if unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Oil Co-op <noreply@example.com>"
